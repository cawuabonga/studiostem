rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isSuperAdmin(userId) {
      return getUserData(userId).role == 'SuperAdmin';
    }

    function isMemberOfInstitute(userId, instituteId) {
      return getUserData(userId).instituteId == instituteId;
    }

    function isInstituteAdmin(userId, instituteId) {
        let userRole = getUserData(userId).role;
        return isMemberOfInstitute(userId, instituteId) && (userRole == 'Admin' || userRole == 'Coordinator');
    }

    function isTeacher(userId, instituteId) {
        return isMemberOfInstitute(userId, instituteId) && getUserData(userId).role == 'Teacher';
    }

    function isStudent(userId, instituteId) {
        return isMemberOfInstitute(userId, instituteId) && getUserData(userId).role == 'Student';
    }

    // Rules for top-level collections
    match /users/{userId} {
      // Allow read/write for the user themselves, or for a SuperAdmin
      allow read, write: if request.auth.uid == userId || isSuperAdmin(request.auth.uid);
      // Allow list read only for SuperAdmins
      allow list: if isSuperAdmin(request.auth.uid);
    }

    match /config/{docId=**} {
        // Allow read for authenticated users (for login page design)
        allow read: if request.auth != null;
        // Allow write only for SuperAdmins
        allow write: if isSuperAdmin(request.auth.uid);
    }
    
    // Rules for institute-specific subcollections
    match /institutes/{instituteId}/{document=**} {
        // SuperAdmins have full access to all institute data
        allow read, write: if isSuperAdmin(request.auth.uid);
    }

    match /institutes/{instituteId} {
        // Any authenticated user can read the list of institutes
        allow get, list: if request.auth != null;
    }

    match /institutes/{instituteId}/staffProfiles/{staffId} {
        allow read, list, write: if isInstituteAdmin(request.auth.uid, instituteId);
    }

    match /institutes/{instituteId}/studentProfiles/{studentId} {
        allow read, list, write: if isInstituteAdmin(request.auth.uid, instituteId);
    }
    
    match /institutes/{instituteId}/programs/{programId} {
        allow read, list, write: if isInstituteAdmin(request.auth.uid, instituteId);
    }

    match /institutes/{instituteId}/unidadesDidacticas/{unitId} {
        allow read, list, write: if isInstituteAdmin(request.auth.uid, instituteId);
        // Teachers can read units they are assigned to (more specific rules needed for writes)
        allow get: if isTeacher(request.auth.uid, instituteId) || isStudent(request.auth.uid, instituteId);
    }

    match /institutes/{instituteId}/unidadesDidacticas/{unitId}/{subcollection}/{docId} {
        allow read, write: if isInstituteAdmin(request.auth.uid, instituteId) || isTeacher(request.auth.uid, instituteId);
        allow read: if isStudent(request.auth.uid, instituteId);
    }

    match /institutes/{instituteId}/assignments/{assignmentId} {
        allow read, write: if isInstituteAdmin(request.auth.uid, instituteId);
    }
    
    match /institutes/{instituteId}/payments/{paymentId} {
        allow read, list: if isInstituteAdmin(request.auth.uid, instituteId);
        allow create: if isStudent(request.auth.uid, instituteId) && request.resource.data.studentId == getUserData(request.auth.uid).documentId;
        allow update: if isInstituteAdmin(request.auth.uid, instituteId);
    }

     match /institutes/{instituteId}/paymentConcepts/{conceptId} {
        allow read, list: if request.auth != null;
        allow write: if isInstituteAdmin(request.auth.uid, instituteId);
     }

    match /institutes/{instituteId}/matriculations/{matriculationId} {
        allow read, list, write: if isInstituteAdmin(request.auth.uid, instituteId);
        allow get, list: if isStudent(request.auth.uid, instituteId) && getUserData(request.auth.uid).documentId == resource.data.studentId;
    }

    match /institutes/{instituteId}/academicRecords/{recordId} {
        allow read, write: if isInstituteAdmin(request.auth.uid, instituteId) || isTeacher(request.auth.uid, instituteId);
        allow get: if isStudent(request.auth.uid, instituteId) && getUserData(request.auth.uid).documentId == resource.data.studentId;
    }

    match /institutes/{instituteId}/attendance/{attendanceId} {
       allow read, write: if isInstituteAdmin(request.auth.uid, instituteId) || isTeacher(request.auth.uid, instituteId);
    }
  }
}
