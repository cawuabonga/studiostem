rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSuperAdmin(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'SuperAdmin';
    }

    function isStaffOfInstitute(userId, instituteId) {
      let user = get(/databases/$(database)/documents/users/$(userId)).data;
      let staffRoles = ['Admin', 'Coordinator', 'Teacher', 'SuperAdmin'];
      return user.instituteId == instituteId && user.role in staffRoles;
    }
    
    function isUserOfInstitute(userId, instituteId) {
        let user = get(/databases/$(database)/documents/users/$(userId)).data;
        return user.instituteId == instituteId;
    }

    function isOwnerByDocId(userId, docId) {
        return get(/databases/$(database)/documents/users/$(userId)).data.documentId == docId;
    }

    // --- Global Collections ---
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isSuperAdmin(request.auth.uid);
      allow update: if request.auth.uid == userId || isSuperAdmin(request.auth.uid);
      allow create, delete: if isSuperAdmin(request.auth.uid);
    }
    
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && isSuperAdmin(request.auth.uid);
    }

    // --- Institute Subcollections ---
    match /institutes/{instituteId} {
      allow read: if true;
      allow write: if request.auth != null && isSuperAdmin(request.auth.uid);

      match /staffProfiles/{staffId} {
        // Allow authenticated users to search for their profile to link it.
        // Allow any user of the institute to view staff profiles (for directories etc).
        allow read: if request.auth != null; 
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }

      match /studentProfiles/{studentId} {
         // Allow authenticated users to search for their profile to link it.
         // Allow any user of the institute to view student profiles.
        allow read: if request.auth != null;
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
      match /programs/{programId} {
        allow read: if true;
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
      match /unidadesDidacticas/{unitId}/{document=**} {
          allow read: if true;
          allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }

      match /roles/{roleId} {
        allow read: if request.auth != null && isUserOfInstitute(request.auth.uid, instituteId);
        allow write: if isSuperAdmin(request.auth.uid);
      }

      match /matriculations/{matriculationId} {
        allow read: if (request.auth != null && isOwnerByDocId(request.auth.uid, resource.data.studentId)) || isStaffOfInstitute(request.auth.uid, instituteId);
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }

      match /academicRecords/{recordId} {
        allow read: if (request.auth != null && isOwnerByDocId(request.auth.uid, resource.data.studentId)) || isStaffOfInstitute(request.auth.uid, instituteId);
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }

      match /attendance/{attendanceId} {
        allow read: if (request.auth != null && isUserOfInstitute(request.auth.uid, instituteId));
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
      match /payments/{paymentId} {
        allow create: if request.auth != null;
        allow read: if (request.auth != null && isOwnerByDocId(request.auth.uid, resource.data.studentId)) || isStaffOfInstitute(request.auth.uid, instituteId);
        allow update: if isStaffOfInstitute(request.auth.uid, instituteId);
        allow delete: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
       match /paymentConcepts/{conceptId} {
        allow read: if request.auth != null;
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }

      // Default deny for any other collections within an institute
      match /{collection}/{docId} {
        allow read, write: if false;
      }
    }
  }
}
