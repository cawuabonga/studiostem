
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions for Development ---
    function isSuperAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    
    function isAssociatedWithInstitute() {
      // Checks if the user is signed in and has an instituteId in their user document.
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId != null;
    }
    
    // --- General Access Rule for Development ---
    // Allows any authenticated user associated with an institute OR a SuperAdmin to read/write.
    match /{path=**} {
      allow read, write: if isAssociatedWithInstitute() || isSuperAdmin();
    }
    
    // --- EXCEPTIONS TO THE GENERAL RULE ---

    // Exception 1: Allow a user to manage their own user document.
    // This is critical for login, profile creation, and profile linking.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Exception 2: Allow public read-only access to collections needed for public-facing pages.
    match /config/{documents=**} {
      allow get: if true;
    }
    match /institutes/{instituteId} {
      allow get: if true;
    }
    match /institutes/{instituteId}/news/{newsId} {
      allow get: if true;
    }
    match /institutes/{instituteId}/programs/{programId} {
      allow get: if true;
    }
    match /institutes/{instituteId}/albums/{albumId}/{photos=**} {
      allow get: if true;
    }
  }
}
