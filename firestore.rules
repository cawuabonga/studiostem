
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rules for Users collection
    match /users/{userId} {
      // Read: Admins can list and get all users. Users can only get their own profile.
      allow get: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      allow list: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      
      // Create: Users can create their own document upon signup.
      allow create: if request.auth.uid == userId;

      // Update: Admins can update any profile. Users can update their own.
      allow update: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';

      // Delete: Only admins can delete user documents.
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Rules for App Settings (login image)
    match /appSettings/{settingId} {
      // Read: Anyone can read settings (e.g., login image for unauthenticated users).
      allow read: if true;
      // Write: Only admins can change settings.
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Rules for core academic data collections.
    // Read: Any authenticated user can read this data (e.g., for dropdowns, reports).
    // Write: Only admins can create, update, or delete records.
    match /studyPrograms/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    match /didacticUnits/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    match /teachers/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    match /unitAssignments/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
  }
}
