
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    
    function isInstituteAdmin(instituteId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userDoc.instituteId == instituteId && userDoc.role in ['Admin'];
    }

    function isInstituteMemberWithRole(instituteId, roles) {
       let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
       return userDoc.instituteId == instituteId && userDoc.role in roles;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Config collection (for login design) is read-only for all, writeable by SuperAdmin
    match /config/{docId=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Institutes collection is readable by any authenticated user, writeable by SuperAdmin
    match /institutes/{instituteId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
      
      // Allow Admins and Coordinators to manage academic and staff data within their institute
      match /{collection}/{docId} {
        allow read, write: if isInstituteMemberWithRole(instituteId, ['Admin', 'Coordinator']);
      }
    }
    
    // Users can read/update their own data. SuperAdmins can manage any user.
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      
      // Complex update logic for user self-validation
      allow update: if isSuperAdmin() || 
                      (isOwner(userId) && 
                        // Allow normal profile updates
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'dni'])) ||
                        // Allow one-time validation update
                        (!resource.data.isVerified && request.resource.data.isVerified == true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'role', 'instituteId', 'displayName', 'email', 'dni', 'phone', 'condition', 'programId']))
                      );
                      
      allow create: if request.auth != null; // Any authenticated user can create their own user document
    }
    
    // Allow any authenticated user to search for profiles to validate their account
    match /{path=**}/staffProfiles/{dni} {
        allow read: if request.auth != null;
    }
    
     match /{path=**}/studentProfiles/{dni} {
        allow read: if request.auth != null;
    }
  }
}
