rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Rules for accessing institute data
    match /institutes/{instituteId}/{document=**} {
      // Allow read access if the user is a SuperAdmin or belongs to the institute.
      allow read: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin' || 
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId);
      
      // Allow write access if the user is a SuperAdmin or an Admin/Coordinator of the institute.
      allow write: if request.auth != null &&
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin' ||
                        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId &&
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator']));
    }

    // Rules for the `users` collection itself
    match /users/{userId} {
        // SuperAdmins can read/write any user document.
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';

        // An institute admin/coordinator can read users of their own institute.
        allow read: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == resource.data.instituteId &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator'];
        
        // A user can update their own profile information, but cannot change their role or institute.
        allow update: if request.auth != null && request.auth.uid == userId &&
                       !('role' in request.resource.data) &&
                       !('instituteId' in request.resource.data);
    }

    // Unauthenticated users can read login design settings for the login page
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    match /config/loginDesign/images/{imageId} {
      allow read: if true;
      allow write, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    // This rule allows a user to validate their profile by checking against all Staff/Student profiles
    match /{path=**}/staffProfiles/{profileId} {
      allow get: if request.auth != null;
    }

    match /{path=**}/studentProfiles/{profileId} {
      allow get: if request.auth != null;
    }
  }
}
