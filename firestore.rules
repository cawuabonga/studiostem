rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    
    function isInstituteAdmin(instituteId) {
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      let userInstituteId = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId;
      return (userRole == 'Admin' || userRole == 'Coordinator') && userInstituteId == instituteId;
    }

    // /users/{userId}
    match /users/{userId} {
      // Any authenticated user can create their own user document
      allow create: if request.auth != null;

      // Users can read their own data. SuperAdmins can read anyone's data.
      allow read: if request.auth.uid == userId || isSuperAdmin();
      
      // Users can update their own non-critical data.
      // A user can also perform a one-time update to claim a profile.
      allow update: if request.auth.uid == userId &&
                      (
                        // Allow updating non-critical fields anytime
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'dni']) ||
                        // Allow one-time profile claim
                        (
                          resource.data.isVerified == false &&
                          request.resource.data.isVerified == true &&
                           request.resource.data.diff(resource.data).affectedKeys().hasAll(['isVerified', 'role', 'instituteId', 'dni', 'displayName', 'email'])
                        )
                      );
      
      // SuperAdmins can update any user
      allow update: if isSuperAdmin();

      // No one can delete user documents for safety. This should be handled by a SuperAdmin or via Cloud Functions.
      allow delete: if false;
    }
    
    // /config/{document}
    match /config/{docId} {
        // Login design settings are public-read, but write-only for SuperAdmins
        allow read: if docId == 'loginDesign';
        allow write: if isSuperAdmin();
        
        match /{allChildren=**} {
             allow read: if docId == 'loginDesign';
             allow write: if isSuperAdmin();
        }
    }

    // /institutes/{instituteId}
    match /institutes/{instituteId} {
      // Allow SuperAdmins to do anything
      allow read, write: if isSuperAdmin();
      
      // Allow institute members (Admin, Coordinator) to read their own institute's data
      allow read: if isInstituteAdmin(instituteId);

      // Subcollections within an institute
      match /{collectionId}/{docId} {
        // Admins/Coordinators can read/write data within their own institute
        allow read, write: if isInstituteAdmin(instituteId);
      }
    }
    
    // collectionGroup for profile validation
    match /{path=**}/staffProfiles/{dni} {
        // Allow any authenticated user to perform a 'get' or a 'query' on this collection group.
        // This is safe because our queries are specific (e.g., where('dni', '==', value))
        // and do not allow listing all documents.
        allow get, list: if request.auth != null;
    }
    
     match /{path=**}/studentProfiles/{dni} {
        // Allow any authenticated user to perform a 'get' or a 'query' on this collection group.
        allow get, list: if request.auth != null;
    }
  }
}
