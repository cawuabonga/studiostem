
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write to their own document.
    // New users can create their own document.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid != null;
    }

    // Public configuration is readable by anyone
    match /config/loginDesign {
        allow read: if true;
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
     match /config/loginDesign/images/{imageId} {
        allow read: if true;
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }


    // Institutes can only be managed by SuperAdmins.
    // Data within an institute can be read by its members.
    match /institutes/{instituteId} {
      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';

      // All subcollections within an institute
      match /{collection}/{docId} {
         allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId ||
                               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
      }
    }
  }
}
