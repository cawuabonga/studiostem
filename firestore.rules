rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check user role
    function isRole(uid, role) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role == role;
    }
    
    function isRoleIn(uid, roles) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role in roles;
    }
    
    function isInstituteMember(uid, instituteId) {
        return get(/databases/$(database)/documents/users/$(uid)).data.instituteId == instituteId;
    }
    
    function isSignedIn() {
        return request.auth != null;
    }

    // Users collection:
    // - Anyone can create their own user document on signup.
    // - Users can only read/update their own document.
    // - Admins/SuperAdmins can read/update any user document.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isRole(request.auth.uid, 'SuperAdmin'));
      
      // Allow update for own profile, or if user is an Admin/SuperAdmin.
      // A user can only perform the "validation" update once.
      allow update: if isSignedIn() && 
                      (request.auth.uid == userId && 
                        (
                          // Standard profile edit (cannot change role/institute)
                          (!('role' in request.resource.data) && !('instituteId' in request.resource.data)) ||
                          // One-time validation update
                          (resource.data.isVerified == false && request.resource.data.isVerified == true)
                        )
                      ) || isRole(request.auth.uid, 'SuperAdmin');
                      
      // On sign up, a user creates their own document.
      allow create: if request.auth.uid == userId;
    }

    // Config collection (e.g., login design)
    // - Public read for login page design.
    // - Write restricted to SuperAdmins.
    match /config/{docId=**} {
      allow read: if true; // Public read is needed for login page styling
      allow write: if isRole(request.auth.uid, 'SuperAdmin');
    }

    // Institutes collection:
    // - Any authenticated user can read institute details (for selection).
    // - Only SuperAdmins can create, update, or delete institutes.
    match /institutes/{instituteId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isRole(request.auth.uid, 'SuperAdmin');

      // Subcollections for institute-specific data
      // Only users who are members of that institute and have the correct role can access them.
      function canAccessInstituteData() {
        return isSignedIn() &&
               isInstituteMember(request.auth.uid, instituteId) &&
               isRoleIn(request.auth.uid, ['Admin', 'Coordinator', 'Teacher']);
      }
      
      match /programs/{programId=**} {
        allow read: if canAccessInstituteData();
        allow write: if canAccessInstituteData() && isRoleIn(request.auth.uid, ['Admin', 'Coordinator']);
      }
      
      match /units/{unitId=**} {
        allow read: if canAccessInstituteData();
        allow write: if canAccessInstituteData() && isRoleIn(request.auth.uid, ['Admin', 'Coordinator']);
      }
      
      match /teachers/{teacherId=**} {
        allow read: if canAccessInstituteData();
        allow write: if canAccessInstituteData() && isRoleIn(request.auth.uid, ['Admin', 'Coordinator']);
      }

      // Profiles to be claimed by users
      match /studentProfiles/{dni} {
        // Admins can manage profiles.
        allow write: if isInstituteMember(request.auth.uid, instituteId) && isRoleIn(request.auth.uid, ['Admin', 'Coordinator']);
        // Admins can read the list of profiles for their institute.
        allow list: if isInstituteMember(request.auth.uid, instituteId) && isRoleIn(request.auth.uid, ['Admin', 'Coordinator']);
        // Any authenticated user can read a SPECIFIC profile doc (for validation).
        allow get: if isSignedIn();
        // Allow a user to update a profile to "claim" it.
        allow update: if isSignedIn() && request.resource.data.claimed == true && resource.data.claimed == false;
      }
      
       match /staffProfiles/{dni} {
        // Admins can manage profiles.
        allow write: if isInstituteMember(request.auth.uid, instituteId) && isRoleIn(request.auth.uid, ['Admin', 'Coordinator']);
        // Admins can read the list of profiles for their institute.
        allow list: if isInstituteMember(request.auth.uid, instituteId) && isRoleIn(request.auth.uid, ['Admin', 'Coordinator']);
        // Any authenticated user can read a SPECIFIC profile doc (for validation).
        allow get: if isSignedIn();
        // Allow a user to update a profile to "claim" it.
        allow update: if isSignedIn() && request.resource.data.claimed == true && resource.data.claimed == false;
      }
    }
  }
}
