rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for SuperAdmin role
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    // Rules for the 'institutes' collection
    // Anyone authenticated can read institute info (name, logo, etc.)
    // Only SuperAdmins can create, update, or delete institutes.
    match /institutes/{instituteId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Rules for the 'users' collection
    // Users can read and update their own profile.
    // SuperAdmins can read and write any user's profile.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isSuperAdmin();
      allow update: if request.auth.uid == userId || isSuperAdmin();
      // Only SuperAdmin should create users via backend/functions, so deny client-side creation.
      // Sign-up process will create a doc, but we can lock down fields later if needed.
      // For now, allow create for any new authenticated user.
      allow create: if request.auth.uid == userId;
      allow delete: if isSuperAdmin(); // Only SuperAdmin can delete users
    }
    
    // Default deny: Disallow read/write to any other collection by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
