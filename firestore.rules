rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    // Checks if the requesting user belongs to a specific institute
    function isUserInInstitute(instituteId) {
      return request.auth.uid != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId;
    }

    // Gets the role of the requesting user
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // --- User Profiles ---
    // Users can create their own doc, and only read/update their own doc.
    match /users/{userId} {
      allow create: if request.auth.uid != null;
      allow read, update: if request.auth.uid == userId;
    }

    // --- Institute Subcollections ---
    match /institutes/{instituteId} {

        // Staff Profiles can be read by any authenticated user for linking purposes.
        // Writes are restricted to admins/coordinators of that institute.
        match /staffProfiles/{profileId} {
            allow read: if request.auth.uid != null;
            allow write: if isUserInInstitute(instituteId) && (userRole() == 'Admin' || userRole() == 'Coordinator');
        }

        // Student Profiles can be read by any authenticated user for linking purposes.
        // Writes are restricted to admins/coordinators of that institute.
        match /studentProfiles/{profileId} {
            allow read: if request.auth.uid != null;
            allow write: if isUserInInstitute(instituteId) && (userRole() == 'Admin' || userRole() == 'Coordinator');
        }

        // --- Generic Rules for other subcollections ---
        // This rule applies to any other collection inside an institute document.
        // Allows read/write access only to users who are part of that institute.
        match /{document=**} {
            allow read, write: if isUserInInstitute(instituteId);
        }
    }
  }
}
