
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isOneOfRoles(roles) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if request.auth.uid == userId && request.resource.data.keys().hasOnly(['displayName', 'photoURL', 'dni']);
    }

    match /loginImages/{imageId} {
      // Anyone can read the login images
      allow read;
      // Only Admins can create or delete login images
      allow create, delete: if isRole('Admin');
      // Only Admins can update.
      // The rule allows updating only 'isActive' or 'url' fields.
      // The URL validation only runs if the 'url' field is being changed.
      allow update: if isRole('Admin')
                    && (
                        (request.resource.data.keys().hasAll(['isActive']) && !request.resource.data.keys().hasAny(['url', 'createdAt'])) ||
                        (request.resource.data.url.matches('^data:image/.*;base64,.*$'))
                      );
    }
    
    match /didacticUnits/{unitId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOneOfRoles(['Admin', 'Coordinator']);
    }
    
    match /studyPrograms/{programId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isRole('Admin');
    }
    
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOneOfRoles(['Admin', 'Coordinator']);
    }
    
    match /unitAssignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create, delete: if isOneOfRoles(['Admin', 'Coordinator']);
    }
  }
}
