rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones de ayuda
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Colección: users
    // Reglas:
    // - Los administradores pueden leer/escribir cualquier documento de usuario.
    // - Los usuarios autenticados pueden leer/escribir su propio documento.
    match /users/{userId} {
      allow read, write: if isAdmin() || request.auth.uid == userId;
    }

    // Colección: appSettings
    // Reglas:
    // - Cualquiera (incluso usuarios no autenticados) puede leer la configuración (ej: imagen de inicio de sesión).
    // - Solo los administradores pueden escribir/actualizar la configuración.
    match /appSettings/{docId} {
        allow read: if true;
        allow write: if isAdmin();
    }
    
    // Colección: studyPrograms
    // Reglas:
    // - Cualquier usuario autenticado puede leer los programas de estudio.
    // - Solo los administradores pueden crear, actualizar o eliminar programas de estudio.
    // - Validación: Asegura que los campos requeridos (name, code, abbreviation) estén presentes y sean del tipo correcto.
    match /studyPrograms/{programId} {
        allow read: if isAuth();
        allow write: if isAdmin() && 
                      request.resource.data.name is string && request.resource.data.name.size() > 0 &&
                      request.resource.data.code is string && request.resource.data.code.size() > 0 &&
                      request.resource.data.abbreviation is string && request.resource.data.abbreviation.size() > 0;
    }
    
    // Colección: teachers
    // Reglas:
    // - Cualquier usuario autenticado puede leer los datos de los docentes.
    // - Solo los administradores pueden crear, actualizar o eliminar docentes.
    // - Validación: Asegura que los campos requeridos estén presentes y sean del tipo correcto.
    match /teachers/{teacherId} {
        allow read: if isAuth();
        allow write: if isAdmin();
    }
    
    // Colección: didacticUnits
    // Reglas:
    // - Cualquier usuario autenticado puede leer los datos de las unidades.
    // - Solo los administradores pueden crear, actualizar o eliminar unidades.
    // - Validación: Asegura que los campos requeridos estén presentes y tengan los tipos/valores correctos.
    match /didacticUnits/{unitId} {
        allow read: if isAuth();
        allow write: if isAdmin();
    }

    // Colección: unitAssignments
    // Reglas:
    // - Cualquier usuario autenticado puede leer los datos de las asignaciones.
    // - Solo los administradores pueden crear, actualizar o eliminar asignaciones.
    // - Validación: Asegura que los campos requeridos estén presentes y tengan los tipos/valores correctos.
    match /unitAssignments/{assignmentId} {
        allow read: if isAuth();
        allow write: if isAdmin();
    }
  }
}
