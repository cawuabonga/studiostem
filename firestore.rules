rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- User Management Rules ---
    match /users/{userId} {
      // Anyone can create their own user document (on signup).
      allow create: if request.auth.uid == userId;

      // Users can only read their own document. SuperAdmins can read any.
      allow read: if request.auth.uid == userId 
                  || (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin');
                  
      // Allow users to update their own profile, but with restrictions on role/institute changes.
      allow update: if request.auth.uid == userId &&
                      // Prevent users from changing their own role or instituteId directly after verification.
                      (request.resource.data.role == resource.data.role &&
                       request.resource.data.instituteId == resource.data.instituteId) ||
                      // Allow a one-time update for profile validation.
                      (resource.data.isVerified == false && request.resource.data.isVerified == true);

      // Only SuperAdmins can delete users.
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    // --- Institute and Subcollection Rules ---
    match /institutes/{instituteId} {
      // SuperAdmins can manage institutes. Authenticated users can read their own institute's data.
      allow read: if request.auth != null && 
                   (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin'
                    || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId);
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';

      // --- Staff & Student Profiles ---
      match /staffProfiles/{dni} {
        // Admins/Coordinators can manage staff profiles within their own institute.
        allow write: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId &&
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator']);

        // Users can claim their profile.
        allow update: if request.auth != null && request.resource.data.claimed == true && resource.data.claimed == false;
      }
      
      match /studentProfiles/{dni} {
         // Admins/Coordinators can manage student profiles within their own institute.
        allow write: if request.auth != null &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId &&
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator']);
        
        // Users can claim their profile.
        allow update: if request.auth != null && request.resource.data.claimed == true && resource.data.claimed == false;
      }

      // --- Generic Subcollection Rules ---
      match /{collection}/{docId} {
        // Admins/Coordinators can manage data within their own institute.
        allow read, write, delete: if request.auth != null && 
                                  (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId &&
                                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator']);
      }
    }
    
    // Allow any authenticated user to query for a profile to validate.
    // This is safe because queries are still restricted by rules on the queried documents.
     match /{path=**}/staffProfiles/{dni} {
      allow list: if request.auth != null;
    }
     match /{path=**}/studentProfiles/{dni} {
      allow list: if request.auth != null;
    }
    
    // --- Public Configuration Rules ---
    match /config/loginDesign {
        // Allow public read for the login page design.
        allow read: if true;
        // Only SuperAdmins can write to the login page design.
        allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';

        // Rules for the 'images' subcollection within 'loginDesign'.
        match /images/{imageId} {
             // Only SuperAdmins can manage login images.
             allow read, write, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
        }
    }
  }
}
