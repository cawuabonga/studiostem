rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to get the user's role data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function to check if the user is a SuperAdmin
    function isSuperAdmin() {
      return isSignedIn() && getUserData().role == 'SuperAdmin';
    }

    // Helper function to check if the user is an admin of a specific institute
    function isInstituteAdmin(instituteId) {
      return isSignedIn() && getUserData().instituteId == instituteId && (getUserData().role == 'Admin' || getUserData().role == 'Coordinator');
    }
    
    // Helper function to check if the user belongs to a specific institute
    function belongsToInstitute(instituteId) {
        return isSignedIn() && getUserData().instituteId == instituteId;
    }

    // --- Rules for collections ---

    // Users can create and manage their own document. SuperAdmins can list/get any user.
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read, update: if request.auth.uid == userId || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow delete: if false; // Nobody can delete a user document from the client
    }

    // Config is public read, but only SuperAdmin can write.
    match /config/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Institute list is public for any authenticated user, but only SuperAdmin can write.
    match /institutes/{instituteId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }
    
    // Specific rules for institute subcollections
    match /institutes/{instituteId}/{collectionId}/{document=**} {
        allow read, write: if belongsToInstitute(instituteId);
    }

    // More granular rules for specific subcollections if needed
    match /institutes/{instituteId}/staffProfiles/{profileId} {
      allow read: if belongsToInstitute(instituteId);
      allow create, update, delete: if isInstituteAdmin(instituteId);
    }
    
    match /institutes/{instituteId}/studentProfiles/{profileId} {
      allow read: if belongsToInstitute(instituteId);
      allow create, update, delete: if isInstituteAdmin(instituteId);
    }
  }
}
