rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- Users Collection ---
    // Anyone can read their own user document.
    // SuperAdmins can read/write any user document.
    // Institute Admins can update roles of users in their institute.
    // Users can create their own document on sign-up.
    // Users can update their own profile info.
    match /users/{userId} {
      allow read: if request.auth.uid == userId 
                  || request.auth.token.role == 'SuperAdmin';
                  
      allow create: if request.auth.uid == userId;

      allow update: if request.auth.uid == userId
                    // Allow SuperAdmin to change anything
                    || request.auth.token.role == 'SuperAdmin'
                    // Allow institute admin to change role of users in their institute
                    || (request.auth.token.role in ['Admin', 'Coordinator'] 
                        && request.auth.token.instituteId == resource.data.instituteId
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']));

    }

    // --- Config Collection (Login Design) ---
    // Anyone can read login design settings (for the login page).
    // Only SuperAdmins can write to login design settings.
    match /config/loginDesign {
        allow read: if true;
        allow write: if request.auth.token.role == 'SuperAdmin';

        // Images subcollection for login page
        match /images/{imageId} {
            allow read, write: if request.auth.token.role == 'SuperAdmin';
        }
    }

    // --- Institutes Collection ---
    // Only SuperAdmins can manage institutes.
    // Any authenticated user can read a single institute's data (needed for dashboard display).
    match /institutes/{instituteId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == 'SuperAdmin';
      
      // Institute Subcollections (programs, units, teachers, etc.)
      // Only Admins or Coordinators of that specific institute can manage them.
      match /{subcollection}/{docId} {
          allow read, write, delete: if request.auth.token.role in ['Admin', 'Coordinator']
                                 && request.auth.token.instituteId == instituteId;
      }
      
      // Staff and Student Profiles Subcollections
      match /staffProfiles/{dni} {
        allow read, write, delete: if request.auth.token.role in ['Admin', 'Coordinator']
                                    && request.auth.token.instituteId == instituteId;
      }

      match /studentProfiles/{dni} {
         allow read, write, delete: if request.auth.token.role in ['Admin', 'Coordinator']
                                    && request.auth.token.instituteId == instituteId;
      }
    }

    // --- Collection Group Queries for Profile Validation ---
    // These rules allow the `validateUserWithActivationCode` function to work.
    // It lets ANY authenticated user query across all institutes for a profile
    // matching their DNI and activation code. This is safe because they cannot
    // list all profiles, only check for a specific combination.
    
    match /{path=**}/staffProfiles/{dni} {
      allow get: if request.auth != null;
      allow list: if request.auth != null 
                   && request.query.get('where') != null
                   && request.query.get('where')[0][0] == 'dni'
                   && request.query.get('where')[0][1] == '=='
                   && request.query.get('where')[1][0] == 'activationCode'
                   && request.query.get('where')[1][1] == '==';
    }

    match /{path=**}/studentProfiles/{dni} {
       allow get: if request.auth != null;
       allow list: if request.auth != null 
                   && request.query.get('where') != null
                   && request.query.get('where')[0][0] == 'dni'
                   && request.query.get('where')[0][1] == '=='
                   && request.query.get('where')[1][0] == 'activationCode'
                   && request.query.get('where')[1][1] == '==';
    }
  }
}