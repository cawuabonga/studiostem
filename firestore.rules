
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USERS: Users can read/update their own data. Only they can create their own doc.
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read, update: if request.auth.uid == userId;
      allow delete: if false; // Users cannot delete their own accounts from the app
    }

    // INSTITUTES: Any authenticated user can list/get institutes (needed for profile linking).
    // Only SuperAdmins can create, update, or delete them.
    match /institutes/{instituteId} {
      allow get, list: if request.auth.uid != null;
      allow create, update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';

      // STAFF PROFILES: Any auth user can read (needed for linking). Admins/Coords of that institute can write.
      match /staffProfiles/{profileId} {
        allow read: if request.auth.uid != null;
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId &&
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Coordinator');
      }

      // STUDENT PROFILES: Any auth user can read (needed for linking). Admins/Coords of that institute can write.
      match /studentProfiles/{profileId} {
        allow read: if request.auth.uid != null;
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId &&
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Coordinator');
      }
      
      // All other subcollections (units, assignments, etc.)
      match /{document=**} {
         allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId;
      }
    }

    // CONFIG: Only SuperAdmins can read/write global config
    match /config/{docId=**} {
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
  }
}
