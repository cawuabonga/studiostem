
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getRole(uid) {
        return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function getInstituteId(uid) {
        return get(/databases/$(database)/documents/users/$(uid)).data.instituteId;
    }

    function isStaffOf(instituteId) {
      return isSignedIn() && getInstituteId(request.auth.uid) == instituteId && getRole(request.auth.uid) in ['Admin', 'Coordinator', 'Teacher'];
    }
    
    function isAdminOrCoordinator(instituteId) {
        return isSignedIn() && getInstituteId(request.auth.uid) == instituteId && getRole(request.auth.uid) in ['Admin', 'Coordinator'];
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if !isSignedIn(); // Allow user creation during sign-up
      allow update: if isUser(userId) || isSuperAdmin(); // User can update their own profile, or SuperAdmin can
    }

    // Rules for 'institutes' collection
    match /institutes/{instituteId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();

      // Rules for subcollections within an institute
      match /{collection}/{docId} {
        allow read, write: if isSuperAdmin() || isAdminOrCoordinator(instituteId);
      }
      
       match /studentProfiles/{studentId} {
         allow read, write: if isSuperAdmin() || isAdminOrCoordinator(instituteId);
       }
       
       match /staffProfiles/{staffId} {
         allow read, write: if isSuperAdmin() || isAdminOrCoordinator(instituteId);
       }

       match /payments/{paymentId} {
         allow create: if isSignedIn();
         allow read, update: if isSuperAdmin() || isAdminOrCoordinator(instituteId);
       }
       
       match /unidadesDidacticas/{unitId} {
         allow read: if isSignedIn();
         allow write: if isSuperAdmin() || isAdminOrCoordinator(instituteId);

         match /{subcollection}/{subDocId} {
            allow read: if isStaffOf(instituteId) || isUser(get(/databases/$(database)/documents/institutes/$(instituteId)/studentProfiles/$(subDocId)).data.linkedUserUid);
            allow write: if isStaffOf(instituteId);
         }
       }
    }

    // Configuration: readable by anyone for login design, writable only by SuperAdmin
    match /config/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /images/{imageId} {
         allow read: if true;
         allow write: if isSuperAdmin();
      }
    }
  }
}
