
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read the login design configuration
    match /config/{docId} {
      allow read: if true;
      
      // Allow SuperAdmins to write to login config and images
      match /images/{imageId} {
         allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
      }
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    // Allow users to create and manage their own user document
    match /users/{userId} {
      allow create, read, update: if request.auth.uid == userId;
    }

    // SuperAdmins can manage anything in any institute
    match /institutes/{instituteId}/{document=**} {
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    
    // Rules for verified users belonging to an institute
    function isVerifiedUserOfInstitute(instituteId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth.uid != null && userDoc.isVerified == true && userDoc.instituteId == instituteId;
    }

    function isInstituteAdmin(instituteId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isVerifiedUserOfInstitute(instituteId) && (userDoc.role == 'Admin' || userDoc.role == 'Coordinator');
    }
    
    // Admins/Coordinators can manage their own institute's documents
    match /institutes/{instituteId} {
        allow read, write: if isInstituteAdmin(instituteId);
        
        match /programs/{programId} {
            allow read, write: if isInstituteAdmin(instituteId);
        }
        match /units/{unitId} {
            allow read, write: if isInstituteAdmin(instituteId);
        }
        match /teachers/{teacherId} {
            allow read, write: if isInstituteAdmin(instituteId);
        }
        match /staffProfiles/{dni} {
            allow read, write: if isInstituteAdmin(instituteId);
        }
        match /studentProfiles/{dni} {
             allow read, write: if isInstituteAdmin(instituteId);
        }
    }

    // A user needs to be able to read profiles to validate their own
    match /{path=**}/staffProfiles/{dni} {
      allow read: if request.auth.uid != null;
    }
     match /{path=**}/studentProfiles/{dni} {
      allow read: if request.auth.uid != null;
    }
  }
}
