
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to get user data and roles
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isSuperAdmin(uid) {
      return getUserData(uid).role == 'SuperAdmin';
    }

    function isInstituteMember(instituteId, uid) {
      return getUserData(uid).instituteId == instituteId;
    }

    function isInstituteAdmin(instituteId, uid) {
      let role = getUserData(uid).role;
      return isInstituteMember(instituteId, uid) && (role == 'Admin' || role == 'Coordinator');
    }
    
    function isTeacher(instituteId, uid) {
       let role = getUserData(uid).role;
       return isInstituteMember(instituteId, uid) && role == 'Teacher';
    }
    
    function isStudent(instituteId, uid) {
       let role = getUserData(uid).role;
       return isInstituteMember(instituteId, uid) && role == 'Student';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // SuperAdmins can read/write any user document
      // Any authenticated user can read their own data
      // Any authenticated user can update their own data
      allow read, update: if request.auth != null && (request.auth.uid == userId || isSuperAdmin(request.auth.uid));
      allow write: if isSuperAdmin(request.auth.uid);
      allow list: if request.auth != null && isSuperAdmin(request.auth.uid);
    }
    
     match /config/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && isSuperAdmin(request.auth.uid);
        
        match /{subcollection}/{imageId} {
           allow read: if request.auth != null;
           allow write: if request.auth != null && isSuperAdmin(request.auth.uid);
        }
     }

    // Rules for the 'institutes' collection and its subcollections
    match /institutes/{instituteId} {
      // Any authenticated user can read institute details (name, logo, etc.)
      // SuperAdmins can create, update, delete institutes
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSuperAdmin(request.auth.uid);

      // --- Staff and Student Profiles ---
      match /staffProfiles/{profileId} {
        allow read: if request.auth != null && (isInstituteMember(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
        allow write: if request.auth != null && (isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
      }

      match /studentProfiles/{profileId} {
        allow read: if request.auth != null && (isInstituteMember(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
        allow write: if request.auth != null && (isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
      }
      
      // --- Academic Management ---
      match /programs/{programId} {
         allow read: if request.auth != null && (isInstituteMember(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
         allow write: if request.auth != null && (isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
      }
      
      match /unidadesDidacticas/{unitId} {
         allow read: if request.auth != null && (isInstituteMember(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
         allow write: if request.auth != null && (isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));

         // Subcollections of a unit
         match /{subcollection}/{docId} {
           allow read: if request.auth != null && (isInstituteMember(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
           allow write: if request.auth != null && (isTeacher(instituteId, request.auth.uid) || isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
         }
      }
      
      match /assignments/{assignmentId} {
          allow read, write: if request.auth != null && (isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
      }
      
      match /matriculations/{matriculationId} {
          allow read: if request.auth != null && (isInstituteMember(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
          allow write: if request.auth != null && (isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
      }

      match /academicRecords/{recordId} {
          allow read: if request.auth != null && (isInstituteMember(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
          allow write: if request.auth != null && (isTeacher(instituteId, request.auth.uid) || isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
      }
      
      // --- Administrative Management ---
      match /paymentConcepts/{conceptId} {
          allow read: if request.auth != null && isInstituteMember(instituteId, request.auth.uid);
          allow write: if request.auth != null && isInstituteAdmin(instituteId, request.auth.uid);
      }

      match /payments/{paymentId} {
          allow read: if request.auth != null && isInstituteMember(instituteId, request.auth.uid);
          // Students can create their own payments
          allow create: if request.auth != null && isStudent(instituteId, request.auth.uid) && request.resource.data.studentId == getUserData(request.auth.uid).documentId;
          // Admins can update (approve/reject)
          allow update: if request.auth != null && isInstituteAdmin(instituteId, request.auth.uid);
      }
      
      match /attendance/{attendanceId} {
        allow read, write: if request.auth != null && (isTeacher(instituteId, request.auth.uid) || isInstituteAdmin(instituteId, request.auth.uid) || isSuperAdmin(request.auth.uid));
      }
    }
  }
}
