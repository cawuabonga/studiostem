
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSuperAdmin(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'SuperAdmin';
    }

    function isUserOfInstitute(userId, instituteId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.instituteId == instituteId;
    }
    
    function isStaffOfInstitute(userId, instituteId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId)).data;
      return userDoc.instituteId == instituteId && (userDoc.role == 'Admin' || userDoc.role == 'Coordinator' || userDoc.role == 'SuperAdmin' || userDoc.role == 'Teacher');
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Config collection is public for reading
    match /config/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin(request.auth.uid);
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isSuperAdmin(request.auth.uid);
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isSuperAdmin(request.auth.uid);
      allow delete: if isSuperAdmin(request.auth.uid);
    }

    // Institutes and their subcollections
    match /institutes/{instituteId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin(request.auth.uid);

      // ANY authenticated user of the institute can READ the roles.
      // Only SuperAdmins can WRITE them.
      match /roles/{roleId} {
        allow read: if isUserOfInstitute(request.auth.uid, instituteId);
        allow write: if isSuperAdmin(request.auth.uid);
      }

      // Staff and Student profiles can be read by any institute user, but only managed by staff.
      match /staffProfiles/{staffId} {
        allow read: if isUserOfInstitute(request.auth.uid, instituteId);
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
      match /studentProfiles/{studentId} {
         allow read: if isUserOfInstitute(request.auth.uid, instituteId);
         allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }

      // Allow staff to manage most other collections.
      // More granular rules can be added here if needed.
       match /{collection}/{docId} {
          allow read, write: if isStaffOfInstitute(request.auth.uid, instituteId);
       }
    }
  }
}
