rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda ---
    
    // Verifica si el usuario tiene el rol de 'SuperAdmin' en su documento de usuario global.
    function isSuperAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    
    // Verifica si el usuario está autenticado y ya tiene un instituto asignado en su perfil.
    function isAssociatedWithInstitute() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId != null;
    }
    
    // --- Regla de Acceso General para Desarrollo ---
    // Permite lectura y escritura a cualquier usuario que ya pertenezca a un instituto o que sea SuperAdmin.
    // Esto cubre la mayoría de las operaciones una vez que el usuario ha iniciado sesión y vinculado su perfil.
    match /{path=**} {
      allow read, write: if isAssociatedWithInstitute() || isSuperAdmin();
    }
    
    // --- EXCEPCIONES A LA REGLA GENERAL (Casos Especiales) ---

    // Gestión del documento de usuario propio:
    // Permite que cualquier usuario autenticado lea y escriba su propio documento en la colección /users.
    // Es crítico para el proceso de registro, login y actualización de datos personales.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Proceso de Vinculación de Perfil (Staff):
    // Permite buscar un perfil por ID (get) y actualizarlo (update) para vincular la cuenta.
    // La actualización solo se permite si el campo 'linkedUserUid' está vacío, evitando que se "roben" perfiles ya vinculados.
    match /institutes/{instituteId}/staffProfiles/{staffId} {
      allow get: if request.auth != null;
      allow update: if request.auth != null && (!resource.data.keys().contains('linkedUserUid') || resource.data.linkedUserUid == null || resource.data.linkedUserUid == "");
    }

    // Proceso de Vinculación de Perfil (Estudiantes):
    // Misma lógica que el personal: permite buscar y vincular si el perfil está disponible.
    match /institutes/{instituteId}/studentProfiles/{studentId} {
      allow get: if request.auth != null;
      allow update: if request.auth != null && (!resource.data.keys().contains('linkedUserUid') || resource.data.linkedUserUid == null || resource.data.linkedUserUid == "");
    }

    // Configuración Global del Sistema:
    // Cualquier persona puede leer la configuración (ej. tasas, periodos), pero solo el SuperAdmin puede editarla.
    match /config/{document=**} {
        allow read: if true;
        allow write: if isSuperAdmin();
    }

    // Acceso Público (Página Web del Instituto):
    // Estas colecciones deben ser legibles sin necesidad de estar logueado para que la web pública funcione.
    match /institutes/{instituteId} {
      allow read: if true;
    }
    match /institutes/{instituteId}/news/{newsId} {
      allow read: if true;
    }
    match /institutes/{instituteId}/programs/{programId} {
      allow read: if true;
    }
    match /institutes/{instituteId}/albums/{albumId}/{allPhotos=**} {
      allow read: if true;
    }

    // Denegación por defecto:
    // Si ninguna de las reglas anteriores se cumple, la operación es rechazada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}