rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Users Collection ---
    // Users can read their own data.
    // Admins can read and write any user's data.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      allow create: if request.auth.uid != null;
    }

    // --- Study Programs Collection ---
    // Logged-in users (Admins, Coordinators) can read.
    // Only Admins can write.
    match /studyPrograms/{programId} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator'];
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // --- Didactic Units Collection ---
    // Logged-in users (Admins, Coordinators) can read.
    // Only Admins and Coordinators can write.
    match /didacticUnits/{unitId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator'];
    }

    // --- Teachers Collection ---
    // Logged-in users (Admins, Coordinators) can read.
    // Only Admins and Coordinators can write.
     match /teachers/{teacherId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator'];
    }

    // --- Unit Assignments Collection ---
    // Logged-in users (Admins, Coordinators) can read and write.
    match /unitAssignments/{assignmentId} {
       allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Coordinator'];
    }

    // --- Login Images Collection ---
    match /loginImages/{imageId} {
      // Allow list reads ONLY for the specific query to get the active image.
      // This is less intuitive. We allow any user to 'list' (query) the collection,
      // but the get/read rule below will restrict access to individual documents.
      // The query itself will filter for isActive == true.
      allow list: if true; 

      // Allow anyone to read a document IF it is the active one.
      // This secures individual document reads while allowing the public query.
      allow get: if resource.data.isActive == true;

      // Only Admins can perform create, update, delete operations.
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';

      // Admins can also read any individual document, not just the active one.
      allow get: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';

      // Validation for create/update
      // On create, URL must be a valid base64 image data URI.
      allow create: if request.resource.data.url.matches('^data:image/.*;base64,.*$') &&
                      request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      
      // On update, only validate the URL if it's being changed.
      allow update: if ('url' in request.resource.data && request.resource.data.url != resource.data.url ?
                        request.resource.data.url.matches('^data:image/.*;base64,.*$') : true) &&
                      request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
  }
}
