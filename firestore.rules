rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isUserOfInstitute(instituteId) {
      // For this to work, the user's document in the GLOBAL users collection
      // would need a field like `instituteId` or a map of `institutes`.
      // This is a simplified check assuming a user belongs to one institute.
      // A more complex check might be needed if a user can belong to multiple institutes.
      // For now, we will allow any authenticated user to access any institute data
      // as we don't have the user-to-institute mapping yet.
      // THIS SHOULD BE TIGHTENED IN A PRODUCTION SCENARIO.
      return isSignedIn();
    }
    
    // --- Global User Profiles ---
    // Users collection remains global. It stores login info and roles.
    // In a true multi-tenant system, this might also store which institutes a user belongs to.
    match /users/{userId} {
      // A user can read their own profile.
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // A user can create their own profile document (on signup).
      allow create: if isSignedIn() && request.auth.uid == userId;

      // A user can update their own displayName, photoURL, and DNI.
      allow update: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['displayName', 'photoURL', 'dni']);
                       
      // Admins can read and update any user's profile (e.g., to change their role).
      // This admin check needs to know which institute the admin belongs to
      // and which user they are trying to manage. For now, we assume a global admin.
      // This part of the logic will need refinement as the multi-tenant model matures.
      allow get, update: if isSignedIn() && getUserData(request.auth.uid).role == 'Admin';
    }

    // --- Institute-Specific Data ---
    // All data like teachers, units, etc., is nested under an institute.
    match /institutes/{instituteId} {
      // Allow reading/writing institute data only if the user belongs to that institute.
      allow read, write: if isUserOfInstitute(instituteId);
      
      // Allow any authenticated user to see the list of institutes for now.
      // This could be tightened later.
      allow list: if isSignedIn();

      // Subcollections for each institute
      match /{collection}/{docId} {
        allow read, write: if isUserOfInstitute(instituteId);
      }
      
      // Specific rule for loginImages: allow anyone to read them for the login page.
      match /loginImages/{imageId} {
        allow read: if true; // Publicly readable for the login screen
        allow write: if isUserOfInstitute(instituteId) && getUserData(request.auth.uid).role == 'Admin';
      }
    }
  }
}
