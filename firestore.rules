rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get user data from the 'users' collection
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Checks if the requesting user has the specified role
    function hasRole(role) {
      return request.auth != null && getUserData(request.auth.uid).role == role;
    }

    // Checks if the requesting user belongs to the specified institute
    function isUserOfInstitute(instituteId) {
        return request.auth != null && getUserData(request.auth.uid).instituteId == instituteId;
    }

    // --- Rules for Institutes Collection ---
    // Only SuperAdmins can manage the institutes list
    match /institutes/{instituteId} {
      allow read: if hasRole('SuperAdmin');
      allow create, update, delete: if hasRole('SuperAdmin');
      
      // --- Rules for Institute Subcollections ---
      // These rules apply to teachers, units, programs, etc. nested under an institute.
      match /{collection}/{documentId} {
        // Read access:
        // - SuperAdmins can read anything.
        // - Users belonging to the institute can read data from their own institute.
        allow read: if hasRole('SuperAdmin') || isUserOfInstitute(instituteId);

        // Write access (create, update, delete):
        // - SuperAdmins can write anything.
        // - Admins or Coordinators of the specific institute can write.
        allow write: if hasRole('SuperAdmin') || 
                      (isUserOfInstitute(instituteId) && (hasRole('Admin') || hasRole('Coordinator')));
      }
    }
    
    // --- Rules for Users Collection ---
    match /users/{userId} {
      // Read access:
      // - A user can read their own profile.
      // - A SuperAdmin can read any user profile.
      // - An Admin or Coordinator can read profiles of users from their own institute.
      allow read: if request.auth.uid == userId || hasRole('SuperAdmin') ||
                   (
                     (hasRole('Admin') || hasRole('Coordinator')) &&
                     isUserOfInstitute(getUserData(userId).instituteId)
                   );
                   
      // Create access:
      // - Any authenticated user can create their own user document upon signing up.
      allow create: if request.auth != null && request.auth.uid == userId;

      // Update access:
      // - A user can update their own displayName, photoURL, and dni.
      // - A SuperAdmin can update any field.
      // - An Admin can update specific fields for users within their institute.
      allow update: if request.auth.uid == userId && request.resource.data.keys().hasOnly(['displayName', 'photoURL', 'dni']) ||
                     hasRole('SuperAdmin') ||
                     (
                       hasRole('Admin') &&
                       isUserOfOffice(getUserData(userId).instituteId) &&
                       request.resource.data.keys().hasAny(['displayName', 'role'])
                     );

      // Delete access (generally restricted)
      allow delete: if hasRole('SuperAdmin');
    }
  }
}
