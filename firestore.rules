rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Función para verificar si un usuario es administrador
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Función para verificar si un usuario es coordinador
    function isCoordinator() {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Coordinator';
    }

    // Usuarios: Solo el dueño del perfil o un administrador puede escribir. Cualquiera autenticado puede leer.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // loginImages: Cualquiera puede consultar la imagen activa. Solo los administradores pueden gestionar la colección.
    match /loginImages/{imageId} {
      // Permite la consulta específica para encontrar la imagen activa para la página de inicio de sesión.
      // ¡Esta es la corrección clave!
      allow list: if request.query.limit == 1 && request.query.get("where")[0][1] == "isActive" && request.query.get("where")[0][2] == true;

      // Un administrador puede leer un documento individual directamente si lo necesita.
      allow get: if isAdmin();
      
      // Solo los administradores pueden crear, actualizar o eliminar imágenes.
      allow write: if isAdmin();
    }

    // StudyPrograms: Solo los administradores pueden gestionar los programas de estudio.
    match /studyPrograms/{programId} {
        allow read: if request.auth != null; // Cualquier usuario autenticado puede leer la lista de programas
        allow write: if isAdmin();
    }

    // Teachers: Solo administradores o coordinadores pueden gestionar los docentes.
    match /teachers/{teacherId} {
        allow read: if request.auth != null; // Cualquier usuario autenticado puede leer la lista
        allow write: if isAdmin() || isCoordinator();
    }

    // DidacticUnits: Solo administradores o coordinadores pueden gestionar las unidades didácticas.
    match /didacticUnits/{unitId} {
        allow read: if request.auth != null; // Cualquier usuario autenticado puede leer la lista
        allow write: if isAdmin() || isCoordinator();
    }
    
    // UnitAssignments: Solo administradores o coordinadores pueden gestionar las asignaciones.
    match /unitAssignments/{assignmentId} {
        allow read: if request.auth != null; // Cualquier usuario autenticado puede leer la lista
        allow write: if isAdmin() || isCoordinator();
    }
  }
}
