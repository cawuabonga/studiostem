rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'SuperAdmin';
    }
    
    function isAssociatedWith(instituteId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().instituteId == instituteId;
    }

    // --- Rules ---

    // Public config (e.g., login design)
    match /config/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Login images collection
    match /login_images/{doc=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // User's own document (critical for login and linking)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Public read-only access to institute basic info
    match /institutes/{instituteId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAssociatedWith(instituteId);
    }

    // Exception for Profile Linking: Allow any authenticated user to read profiles to find themselves
    match /institutes/{instituteId}/staffProfiles/{staffId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isAssociatedWith(instituteId);
    }
    match /institutes/{instituteId}/studentProfiles/{studentId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isAssociatedWith(instituteId);
    }

    // Subcollections for public pages (news, albums, programs)
    match /institutes/{instituteId}/news/{newsId} {
      allow read: if true;
    }
    match /institutes/{instituteId}/albums/{albumId}/{photos=**} {
      allow read: if true;
    }
    match /institutes/{instituteId}/programs/{programId} {
      allow read: if true;
    }

    // General access rule for all other institute data
    match /institutes/{instituteId}/{document=**} {
      allow read, write: if isSuperAdmin() || isAssociatedWith(instituteId);
    }
    
    // Global access for SuperAdmin to all other collections
    match /{path=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
