rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isAdmin() {
      return hasRole('Admin');
    }

    function isCoordinator() {
      return hasRole('Coordinator');
    }
    
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAdmin() || (isAuth() && request.auth.uid == userId && request.resource.data.keys().hasOnly(['displayName', 'photoURL']));
    }

    match /loginImages/{imageId} {
      // Allow anyone to perform the specific query for the active image
      allow list: if request.query.resource.data.isActive == true && request.query.limit == 1;

      // Admins can see the full list of images
      allow get, list: if isAdmin();
      
      // Admins can create new images if the URL is a valid data URI
      allow create: if isAdmin()
                    && request.resource.data.url.matches('^data:image/.*;base64,.*$');

      // Admins can update images. The URL format is only checked if it's being changed.
      allow update: if isAdmin() && 
                    (!('url' in request.resource.data) || request.resource.data.url.matches('^data:image/.*;base64,.*$'));
      
      // Admins can delete images
      allow delete: if isAdmin();
    }
    
    match /{collection}/{docId} 
        where collection in ['didacticUnits', 'studyPrograms', 'teachers', 'unitAssignments'] {
        allow read, write: if isAdmin() || isCoordinator();
    }
  }
}
