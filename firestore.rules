
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user data
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    // Helper function to get user role
    function getUserRole(userId) {
      return getUserData(userId).role;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Allow users to read their own data.
      // Allow SuperAdmins to read any user's data.
      allow read: if request.auth.uid == userId || getUserRole(request.auth.uid) == 'SuperAdmin';
      
      // Allow users to update their own profile.
      allow update: if request.auth.uid == userId;
      
      // Allow new users to create their own document upon registration.
      allow create: if request.auth.uid == userId;
      
      // Allow SuperAdmins to write to any user document (for role/institute changes).
      allow write: if getUserRole(request.auth.uid) == 'SuperAdmin';
    }

    // --- INSTITUTES COLLECTION ---
    match /institutes/{instituteId} {
      // Allow any authenticated user to read institute details.
      allow read: if request.auth.uid != null;
      
      // Allow only SuperAdmins to create, update, or delete institutes.
      allow write: if getUserRole(request.auth.uid) == 'SuperAdmin';

      // --- SUBCOLLECTIONS OF AN INSTITUTE ---

      // Helper function to check if a user is staff of the current institute.
      function isStaffOfInstitute() {
          let userData = getUserData(request.auth.uid);
          return userData.instituteId == instituteId && (userData.role == 'Admin' || userData.role == 'Coordinator' || userData.role == 'SuperAdmin');
      }
      
      // Allow SuperAdmins to manage roles for any institute.
      match /roles/{roleId} {
        allow read, write: if getUserRole(request.auth.uid) == 'SuperAdmin';
      }

      // Allow any authenticated user to read profiles.
      // Allow only staff of the institute to write to profiles.
      match /staffProfiles/{staffId} {
        allow read: if request.auth.uid != null;
        allow write: if isStaffOfInstitute();
      }
      
      match /studentProfiles/{studentId} {
         allow read: if request.auth.uid != null;
         allow write: if isStaffOfInstitute();
      }

      // Allow institute staff to manage these collections.
      // More granular rules (e.g., teachers can only edit their own units) would go here.
       match /unidadesDidacticas/{docId} {
          allow read, write: if isStaffOfInstitute();
       }
        match /assignments/{docId} {
          allow read, write: if isStaffOfInstitute();
       }
        match /matriculations/{docId} {
          allow read, write: if isStaffOfInstitute();
       }
       match /academicRecords/{docId} {
          allow read, write: if isStaffOfInstitute();
       }
       match /attendance/{docId} {
          allow read, write: if isStaffOfInstitute();
       }
       match /paymentConcepts/{docId} {
          allow read, write: if isStaffOfInstitute();
       }
       match /payments/{docId} {
          allow read, write: if isStaffOfInstitute();
       }
    }

    // Open read access for general configuration but restrict write access
    match /config/{document=**} {
      allow read: if true;
      allow write: if getUserRole(request.auth.uid) == 'SuperAdmin';
    }
  }
}
