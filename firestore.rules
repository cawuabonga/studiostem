rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can create their own user document, and only read/update their own.
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Nobody can delete user documents from the app
    }

    // Rules for institute-specific data
    match /institutes/{instituteId} {
      // SuperAdmins can manage institutes
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
      
      // Allow any authenticated user to read profiles for the linking process
      match /(staffProfiles|studentProfiles)/{profileId} {
        allow read: if request.auth != null;
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId &&
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Coordinator');
      }

      // Other institute data can only be accessed by users belonging to that institute
      match /{collection}/{docId} {
         allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId;
      }
    }
    
    // Config collections (like login design) are managed by SuperAdmins
    match /config/{docId=**} {
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
  }
}
