{
  "rules": {
    "institutes": {
      "$instituteId": {
        // Allow read access for any authenticated user to their own institute's details
        "allow read": "if request.auth != null && request.auth.token.instituteId == $instituteId;",
        // Allow write access only for SuperAdmins
        "allow write": "if request.auth != null && request.auth.token.role == 'SuperAdmin';",
        
        // Rules for subcollections within an institute
        "programs": {
          "$programId": {
            "allow read, write": "if request.auth != null && request.auth.token.instituteId == $instituteId && (request.auth.token.role == 'Admin' || request.auth.token.role == 'Coordinator');"
          }
        },
        "units": {
          "$unitId": {
            "allow read, write": "if request.auth != null && request.auth.token.instituteId == $instituteId && (request.auth.token.role == 'Admin' || request.auth.token.role == 'Coordinator');"
          }
        },
        "teachers": {
          "$teacherId": {
            "allow read, write": "if request.auth != null && request.auth.token.instituteId == $instituteId && (request.auth.token.role == 'Admin' || request.auth.token.role == 'Coordinator');"
          }
        }
      },
      "allow read": "if request.auth != null && request.auth.token.role == 'SuperAdmin';"
    },
    "users": {
      "$uid": {
        // Users can read their own data, SuperAdmins can read anyone's data
        "allow read": "if request.auth.uid == $uid || (request.auth != null && request.auth.token.role == 'SuperAdmin');",
        // Users can update their own data, SuperAdmins can update anyone's data
        "allow write": "if request.auth.uid == $uid || (request.auth != null && request.auth.token.role == 'SuperAdmin');"
      }
    },
    "config": {
      "loginDesign": {
      	"allow read": "if true;",
        "allow write": "if request.auth != null && request.auth.token.role == 'SuperAdmin';",
        "images": {
            "$imageId": {
                // Allow read for anyone to display images
                "allow read": "if true;",
                 // Allow write only for SuperAdmins to manage images
                "allow write": "if request.auth != null && request.auth.token.role == 'SuperAdmin';"
            }
        }
      }
    }
  }
}