rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isSuperAdmin() {
      return isUserAuthenticated() && getUserRole() == 'SuperAdmin';
    }

    function isInstituteAdminOrCoordinator(instituteId) {
        return isUserAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId
            && (getUserRole() == 'Admin' || getUserRole() == 'Coordinator');
    }

    // --- Global Config ---
    match /config/{document=**} {
      // SuperAdmins can write, any authenticated user can read
      allow read: if isUserAuthenticated();
      allow write: if isSuperAdmin();
    }

    // --- User Profiles ---
    // Users can read/update their own profile.
    // SuperAdmins can read/write any user profile.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow list, write: if isSuperAdmin();
    }
    
    // --- Institutes ---
    match /institutes/{instituteId}/{document=**} {
      // SuperAdmins can manage all institutes.
      // Admins/Coordinators can manage their own institute's data.
      allow read, write: if isSuperAdmin() || isInstituteAdminOrCoordinator(instituteId);
    }
    
    // --- Collection Group for Profile Validation ---
    // A user can query these groups if they are trying to validate their own profile
    // by providing their DNI and activation code. This is secure because they must know both.
    match /{path=**}/staffProfiles/{dni} {
        allow get: if isUserAuthenticated() 
                    && request.resource.data.dni == request.query.dni 
                    && request.resource.data.activationCode == request.query.activationCode;
        allow list: if false; // Disallow listing all profiles
    }
    
     match /{path=**}/studentProfiles/{dni} {
        allow get: if isUserAuthenticated() 
                    && request.resource.data.dni == request.query.dni 
                    && request.resource.data.activationCode == request.query.activationCode;
        allow list: if false; // Disallow listing all profiles
    }
  }
}
