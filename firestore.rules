rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can create, read and update their own profile.
    match /users/{userId} {
      allow create;
      allow read, update: if request.auth.uid == userId;
    }

    // SuperAdmins can manage all users and institutes.
    match /users/{userId} {
      allow list, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    match /institutes/{instituteId} {
        allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    // Config is public for login page design.
     match /config/{docId=**} {
      allow read;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    
    // Institute data can only be accessed by its members.
    match /institutes/{instituteId}/{document=**} {
      allow read, write: if request.auth.uid != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId;
    }
  }
}
