rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección 'users'
    match /users/{userId} {
      // Cualquier usuario puede crear su propio documento de usuario al registrarse
      allow create: if request.auth != null;
      // Los usuarios solo pueden leer y actualizar su propio documento
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // SuperAdmin puede leer y escribir cualquier documento de usuario
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    // Reglas para la colección 'institutes'
    match /institutes/{instituteId} {
      // SuperAdmin puede gestionar todos los institutos
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
      
      // Los usuarios asignados a un instituto pueden leer su información
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId;
      
      // Reglas para las subcolecciones de cada instituto
      match /{subcollection}/{docId=**} {
        // Los admins y coordinadores pueden gestionar los datos de su instituto
        allow read, write: if request.auth != null && 
                             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId &&
                             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
                              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Coordinator');
      }
    }

    // Regla global para la colección de configuración 'config'
    match /config/{docId=**} {
      // PERMITIR LECTURA PÚBLICA: Cualquier persona puede leer la configuración de diseño.
      allow read: if true;
      // Solo el SuperAdmin puede escribir en la configuración.
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    
    // Reglas para la validación de perfiles
    match /{path=**}/staffProfiles/{dni} {
        allow read, update: if request.auth != null;
    }

    match /{path=**}/studentProfiles/{dni} {
        allow read, update: if request.auth != null;
    }
  }
}