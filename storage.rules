rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isSuperAdmin() {
      // Verifica si el usuario autenticado tiene el rol de SuperAdmin en Firestore.
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    // Regla general para todos los archivos.
    match /{allPaths=**} {
      // Cualquiera puede leer los archivos (necesario para mostrar imágenes públicas).
      allow read: if true;

      // La escritura solo se permite a usuarios autenticados.
      allow write: if request.auth != null;
    }
  }
}
