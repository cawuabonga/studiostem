rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to get user's role from Firestore
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Allow public read for login images
    match /login-images/{allPaths=**} {
      allow read: if true;
    }
    
    // Allow write only for SuperAdmins on login images
    match /login-images/{imageId} {
      allow write: if request.auth != null && getUserRole() == 'SuperAdmin';
    }

    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
