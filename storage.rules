
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read access to all files.
    // This is necessary for images to be displayed in the app.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow write (create, update, delete) operations only if the user is authenticated.
    // This is a secure default that prevents anonymous users from uploading files.
    match /{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
