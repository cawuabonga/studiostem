rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read access to login images
    match /login-images/{allPaths=**} {
      allow read: if true;
      // Allow write access (upload, delete) only for SuperAdmins
      allow write: if request.auth != null && request.auth.token.role == 'SuperAdmin';
    }
    
    // Example: Restrict user profile pictures to the owner
    match /users/{userId}/{allPaths=**} {
      allow read: if true; // or make it more restrictive if needed
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
