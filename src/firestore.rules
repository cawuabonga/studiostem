
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSuperAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isStaffOfInstitute(instituteId) {
        let user = getUserData();
        return user.instituteId == instituteId && user.role in ['Admin', 'Coordinator', 'Teacher'];
    }

    function isOwner(userDocId) {
        let user = getUserData();
        return user.documentId == userDocId;
    }

    function isUserOfInstitute(instituteId) {
        let user = getUserData();
        return user.instituteId == instituteId;
    }
    
    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Config ---
    match /config/{document=**} {
        // Public read for login design settings
        allow read: if true;
        // Only SuperAdmins can modify global configurations
        allow write: if isSuperAdmin();
    }
    
    // --- Users Collection ---
    match /users/{userId} {
      // Any user can read their own data.
      allow read: if request.auth.uid == userId;
      // Users can update their own profile, SuperAdmins can update any profile.
      allow write: if request.auth.uid == userId || isSuperAdmin();
    }
    
    // --- Institutes Collection ---
    match /institutes/{instituteId} {
      // Anyone can read institute basic info (name, logo)
      allow read: if true;
      // Only SuperAdmins can create, update, or delete institutes
      allow create, update, delete: if isSuperAdmin();
      
      // --- Institute Subcollections ---

      // Any authenticated user can attempt to read profiles for linking
      match /(staffProfiles|studentProfiles)/{profileId} {
        allow read: if isUserAuthenticated();
        allow write: if isStaffOfInstitute(instituteId);
      }
      
      // Any user of the institute can read roles.
      match /roles/{roleId} {
        allow read: if isUserOfInstitute(instituteId);
        allow write: if isSuperAdmin(); // Role definition managed by SuperAdmins
      }

      // Read access to units and programs is public for any user in the institute
      match /(unidadesDidacticas|programs)/{docId} {
        allow read: if isUserOfInstitute(instituteId);
        allow write: if isStaffOfInstitute(instituteId);
      }

      // Rules for matriculations and academic records
      match /(matriculations|academicRecords)/{recordId} {
         allow read: if isOwner(resource.data.studentId) || isStaffOfInstitute(instituteId);
         allow create, update, delete: if isStaffOfInstitute(instituteId);
      }

      // Rules for attendance
      match /attendance/{docId} {
         allow read, write: if isStaffOfInstitute(instituteId);
      }
      
      // Rules for weekly planner and syllabus
      match /unidadesDidacticas/{unitId}/{collection}/{docId} {
        allow read: if isUserOfInstitute(instituteId);
        allow write: if isStaffOfInstitute(instituteId);
      }
      
      // Rules for assignments (teaching and non-teaching)
      match /(assignments|nonTeachingActivities|nonTeachingAssignments)/{docId} {
          allow read, write: if isStaffOfInstitute(instituteId);
      }

      // Rules for payments
      match /paymentConcepts/{docId} {
          allow read: if isUserOfInstitute(instituteId);
          allow write: if isStaffOfInstitute(instituteId);
      }
      match /payments/{docId} {
          allow read: if isOwner(resource.data.studentId) || isStaffOfInstitute(instituteId);
          allow create: if isOwner(request.resource.data.studentId);
          allow update: if isStaffOfInstitute(instituteId);
      }
    }
  }
}
