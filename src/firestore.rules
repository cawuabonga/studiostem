rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda ---
    
    function isSuperAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }
    
    function isAssociatedWithInstitute() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId != null;
    }
    
    // --- Regla de Acceso General ---
    match /{path=**} {
      allow read, write: if isAssociatedWithInstitute() || isSuperAdmin();
    }
    
    // --- Excepciones ---

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /institutes/{instituteId}/staffProfiles/{staffId} {
      allow get: if request.auth != null;
      allow update: if request.auth != null && (!resource.data.keys().contains('linkedUserUid') || resource.data.linkedUserUid == null || resource.data.linkedUserUid == "");
    }

    match /institutes/{instituteId}/studentProfiles/{studentId} {
      allow get: if request.auth != null;
      allow update: if request.auth != null && (!resource.data.keys().contains('linkedUserUid') || resource.data.linkedUserUid == null || resource.data.linkedUserUid == "");
    }

    match /config/{document=**} {
        allow read: if true;
        allow write: if isSuperAdmin();
    }

    match /institutes/{instituteId} {
      allow read: if true;
    }
    match /institutes/{instituteId}/news/{newsId} {
      allow read: if true;
    }
    match /institutes/{instituteId}/programs/{programId} {
      allow read: if true;
    }
    match /institutes/{instituteId}/albums/{albumId}/{allPhotos=**} {
      allow read: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}