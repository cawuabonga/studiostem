rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin';
    }

    function isInstituteMember(instituteId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId;
    }

    function isInstituteAdmin(instituteId) {
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isInstituteMember(instituteId) && (userRole == 'Admin' || userRole == 'Coordinator');
    }
    
    function isTeacher(instituteId) {
       let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
       return isInstituteMember(instituteId) && userRole == 'Teacher';
    }

    // --- Collection Rules ---

    // Users: Can be created by the user themselves. Can be read/updated by the user OR a SuperAdmin.
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read, update: if request.auth.uid == userId || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow delete: if false; 
    }

    // Config: Publicly readable for login page, but only SuperAdmins can write.
    match /config/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Institutes: List is readable by any signed-in user. Writable only by SuperAdmins.
    match /institutes/{instituteId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // Staff/Student Profiles: Readable by any institute member. Writable by institute admins.
    match /institutes/{instituteId}/staffProfiles/{profileId} {
      allow read: if isInstituteMember(instituteId);
      allow create, update, delete: if isInstituteAdmin(instituteId);
    }
    
    match /institutes/{instituteId}/studentProfiles/{profileId} {
      allow read: if isInstituteMember(instituteId);
      allow create, update, delete: if isInstituteAdmin(instituteId);
    }
    
    // Payments: Can be created by institute members. Can only be read/updated by institute admins or the student who owns it.
     match /institutes/{instituteId}/payments/{paymentId} {
      allow create: if isInstituteMember(instituteId);
      allow read: if isInstituteAdmin(instituteId) || request.auth.uid == resource.data.studentId;
      allow update: if isInstituteAdmin(instituteId);
      allow delete: if false;
    }
    
    // Academic Records, Syllabus, Planning: Writable by teachers/admins, readable by any institute member.
    match /institutes/{instituteId}/unidadesDidacticas/{unitId}/{collection}/{docId} {
       allow read: if isInstituteMember(instituteId);
       allow write: if isInstituteAdmin(instituteId) || isTeacher(instituteId);
    }

    // Default deny for any other subcollections or paths not explicitly defined.
    match /institutes/{instituteId}/{document=**} {
      allow read, write: if isInstituteMember(instituteId);
    }
  }
}
