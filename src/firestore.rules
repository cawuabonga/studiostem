
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda ---
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isSuperAdmin(userId) {
      return getUserData(userId).role == 'SuperAdmin';
    }

    function isMemberOfInstitute(userId, instituteId) {
      return getUserData(userId).instituteId == instituteId;
    }
    
    function isStaffOfInstitute(userId, instituteId) {
      let user = getUserData(userId);
      return user.instituteId == instituteId && (user.role == 'Admin' || user.role == 'Coordinator' || user.role == 'Teacher');
    }

    function isStudentOfInstitute(userId, instituteId) {
      let user = getUserData(userId);
      return user.instituteId == instituteId && user.role == 'Student';
    }

    function hasPermission(userId, permission) {
      let user = getUserData(userId);
      let roleDoc = get(/databases/$(database)/documents/institutes/$(user.instituteId)/roles/$(user.roleId)).data;
      return isSuperAdmin(userId) || (permission in roleDoc.permissions);
    }
    
    // --- Reglas Globales ---

    // Denegar todo por defecto
    match /{document=**} {
      allow read, write: if false;
    }

    // Permitir lectura pública de la configuración de login
    match /config/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin(request.auth.uid);
    }
    
    // Los usuarios pueden crear su propio documento y leerlo/actualizarlo
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read, update: if request.auth.uid == userId;
      allow write: if isSuperAdmin(request.auth.uid);
    }

    // --- Reglas por Instituto ---
    match /institutes/{instituteId} {
      allow read: if isMemberOfInstitute(request.auth.uid, instituteId) || isSuperAdmin(request.auth.uid);
      allow write: if isSuperAdmin(request.auth.uid);

      // Roles: Solo los SuperAdmins pueden escribir. Cualquier miembro del instituto puede leerlos.
      match /roles/{roleId} {
        allow read: if isMemberOfInstitute(request.auth.uid, instituteId) || isSuperAdmin(request.auth.uid);
        allow write: if isSuperAdmin(request.auth.uid);
      }
      
      // Perfiles: Solo el personal del instituto puede escribirlos, pero cualquier miembro puede leerlos.
      match /staffProfiles/{staffId} {
        allow read: if isMemberOfInstitute(request.auth.uid, instituteId);
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
      match /studentProfiles/{studentId} {
         allow read: if isMemberOfInstitute(request.auth.uid, instituteId);
         allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
      // Unidades: Cualquier miembro del instituto puede leer, solo personal escribe.
      match /unidadesDidacticas/{unitId} {
        allow read: if isMemberOfInstitute(request.auth.uid, instituteId);
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);

        // Subcolecciones de Unidades (indicadores, planner, etc.)
         match /{subcollection}/{docId=**} {
            allow read: if isMemberOfInstitute(request.auth.uid, instituteId);
            allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
         }
      }
      
      // Asignaciones: Solo el personal del instituto puede gestionar.
      match /assignments/{assignmentId} {
        allow read, write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
      // Matrículas: Personal puede leer/escribir. Estudiantes solo pueden leer las suyas.
      match /matriculations/{matriculationId} {
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
        allow read: if isStaffOfInstitute(request.auth.uid, instituteId) || resource.data.studentId == getUserData(request.auth.uid).documentId;
      }
      
      // Registros Académicos: Personal puede leer/escribir. Estudiantes solo los suyos.
      match /academicRecords/{recordId} {
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
        allow read: if isStaffOfInstitute(request.auth.uid, instituteId) || resource.data.studentId == getUserData(request.auth.uid).documentId;
      }
      
      // Asistencias: Personal puede leer/escribir. Estudiantes pueden leerlo (se filtra en cliente).
      match /attendance/{attendanceId} {
        allow read: if isMemberOfInstitute(request.auth.uid, instituteId);
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
      
      // Pagos: Personal puede leer todos. Estudiantes leen/escriben los suyos.
      match /payments/{paymentId} {
        allow create: if isStudentOfInstitute(request.auth.uid, instituteId) && request.resource.data.studentId == getUserData(request.auth.uid).documentId;
        allow read: if isStaffOfInstitute(request.auth.uid, instituteId) || resource.data.studentId == getUserData(request.auth.uid).documentId;
        allow update: if isStaffOfInstitute(request.auth.uid, instituteId); // Solo staff puede aprobar/rechazar
      }
      
      // Conceptos de Pago: Personal puede leer/escribir. Estudiantes solo leer.
      match /paymentConcepts/{conceptId} {
        allow read: if isMemberOfInstitute(request.auth.uid, instituteId);
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId);
      }
    }
  }
}
