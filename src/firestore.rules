
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isSuperAdmin(userId) {
      return getUserData(userId).role == 'SuperAdmin';
    }

    function isUserRequestingOwnData(userId) {
        return request.auth.uid == userId;
    }

    function isAuthenticated() {
        return request.auth != null;
    }
    
    function getRolePermissions(instituteId, roleId) {
        return get(/databases/$(database)/documents/institutes/$(instituteId)/roles/$(roleId)).data.permissions;
    }

    function hasPermission(permission) {
        let userData = getUserData(request.auth.uid);
        let instituteId = userData.instituteId;
        let roleId = userData.roleId;

        // SuperAdmin has all permissions
        if (isSuperAdmin(request.auth.uid)) {
            return true;
        }

        // Check for role-based permissions
        if (instituteId != null && roleId != null) {
            let userPermissions = getRolePermissions(instituteId, roleId);
            return permission in userPermissions;
        }

        return false;
    }

    // --- Default Security Rule ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Public Configuration ---
    // Anyone can read the login design, only SuperAdmins can change it.
    match /config/{path=**} {
      allow read: if true;
      allow write: if isSuperAdmin(request.auth.uid);
    }
    
    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isUserRequestingOwnData(userId) || isSuperAdmin(request.auth.uid);
      allow create: if isUserRequestingOwnData(userId); // A user can create their own doc
      allow update: if isUserRequestingOwnData(userId) || isSuperAdmin(request.auth.uid);
      allow delete: if isSuperAdmin(request.auth.uid);
    }
    
    // --- Institute Data ---
    match /institutes/{instituteId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin(request.auth.uid); // Create, Update, Delete institutes

      function isStaffOfInstitute(userId) {
          let userData = getUserData(userId);
          let userInstituteId = userData.instituteId;
          return userInstituteId == instituteId && (
              hasPermission('academic:program:manage') ||
              hasPermission('users:staff:manage') ||
              hasPermission('admin:fees:manage')
          );
      }

      // --- Subcollections ---
      
      // Profiles are readable by any authenticated user for profile pages, writable by staff.
      match /staffProfiles/{staffId} {
        allow read: if isAuthenticated();
        allow write: if isStaffOfInstitute(request.auth.uid);
      }
      
      match /studentProfiles/{studentId} {
         allow read: if isAuthenticated();
         allow write: if isStaffOfInstitute(request.auth.uid);
      }

      // Permissions and Roles managed by SuperAdmins
      match /roles/{roleId} {
        allow read, write: if isSuperAdmin(request.auth.uid);
      }

      // Student can read their own academic records, staff can read/write any.
      match /academicRecords/{recordId} {
        allow read: if isStaffOfInstitute(request.auth.uid) || request.auth.uid == resource.data.studentId;
        allow write: if isStaffOfInstitute(request.auth.uid);
      }

      // Student can read their own matriculations, staff can read/write any.
      match /matriculations/{matriculationId} {
        allow read: if isStaffOfInstitute(request.auth.uid) || request.auth.uid == resource.data.studentId;
        allow write: if isStaffOfInstitute(request.auth.uid);
      }

      // Student can read their own payments, staff can validate.
      match /payments/{paymentId} {
        allow read: if isStaffOfInstitute(request.auth.uid) || request.auth.uid == resource.data.studentId;
        allow create: if request.auth.uid == request.resource.data.studentId; // Student can create their own payment
        allow update: if hasPermission('admin:payments:validate'); // Only users with validation perm can update
      }

      // Remaining collections are managed by staff
       match /{collection}/{docId} {
          allow read, write: if isStaffOfInstitute(request.auth.uid);
       }
    }
  }
}
