rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && getRole() == 'SuperAdmin';
    }

    function isInstituteAdmin(instituteId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId && (getRole() == 'Admin' || getRole() == 'Coordinator');
    }
    
    function belongsToInstitute(instituteId) {
       return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId;
    }

    // --- Rules ---

    // Users can create their own document.
    // They can only be read/updated by the user themselves or a SuperAdmin.
    match /users/{userId} {
      allow create: if isUser(userId);
      allow list: if isSuperAdmin();
      allow read, update: if isUser(userId) || isSuperAdmin();
      allow delete: if false; // Nobody can delete a user document from the client
    }

    // Config is public read, but only SuperAdmin can write.
    match /config/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Institute list is public for any signed-in user, but only SuperAdmin can write.
    match /institutes/{instituteId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // Profiles can be read by any signed-in user of that institute
    // but only written to by admins/coordinators of that institute.
    match /institutes/{instituteId}/staffProfiles/{profileId} {
      allow read: if belongsToInstitute(instituteId);
      allow create, update, delete: if isInstituteAdmin(instituteId);
    }
    
    match /institutes/{instituteId}/studentProfiles/{profileId} {
      allow read: if belongsToInstitute(instituteId);
      allow create, update, delete: if isInstituteAdmin(instituteId);
    }

    // All other subcollections can only be accessed by users belonging to that institute.
    match /institutes/{instituteId}/{document=**} {
      allow read, write: if belongsToInstitute(instituteId);
    }
  }
}
