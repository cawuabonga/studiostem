
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user role
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // A user can create their own user document if the doc ID matches their UID
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read, update: if request.auth.uid == userId || getUserRole(request.auth.uid) == 'SuperAdmin';
      allow write: if getUserRole(request.auth.uid) == 'SuperAdmin';
    }

    // Open read access for general configuration
    match /config/{document=**} {
      allow read: if true;
    }

    // Allow only superadmins to write to config
    match /config/{document=**} {
        allow write: if getUserRole(request.auth.uid) == 'SuperAdmin';
    }

    // Rules for institutes and their subcollections
    match /institutes/{instituteId} {
      // Allow authenticated users to read institute data
      allow read: if request.auth != null;
      // Allow only superadmins to create, update, delete institutes
      allow write: if getUserRole(request.auth.uid) == 'SuperAdmin';

      // Rules for roles subcollection
      match /roles/{roleId} {
        allow read, write: if getUserRole(request.auth.uid) == 'SuperAdmin';
      }

      function isStaffOfInstitute(userId, instituteId) {
          let userDoc = get(/databases/$(database)/documents/users/$(userId)).data;
          return userDoc.instituteId == instituteId && (userDoc.role == 'Admin' || userDoc.role == 'Coordinator' || userDoc.role == 'SuperAdmin');
      }

      // Allow authenticated users to read profiles
      // Allow staff to write to profiles
      // OR allow a user to link themselves to an unlinked profile
      match /staffProfiles/{staffId} {
        allow read: if request.auth != null;
        allow write: if isStaffOfInstitute(request.auth.uid, instituteId) || 
                      (request.auth.uid == request.resource.data.linkedUserUid && resource.data.linkedUserUid == null);
      }
      
      match /studentProfiles/{studentId} {
         allow read: if request.auth != null;
         allow write: if isStaffOfInstitute(request.auth.uid, instituteId) ||
                       (request.auth.uid == request.resource.data.linkedUserUid && resource.data.linkedUserUid == null);
      }

      // Rules for academic records, attendance, etc.
      // Teachers of a unit can write, students can read their own.
       match /{collection}/{docId} {
          allow read, write: if isStaffOfInstitute(request.auth.uid, instituteId);
       }
    }
  }
}
